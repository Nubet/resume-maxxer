{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResumeData",
  "description": "Universal JSON schema for ATS-optimized resumes in Resume Maxxer",
  "type": "object",
  "required": ["metadata", "basics", "experience", "education", "skills"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["language", "schema_version", "template_id"],
      "properties": {
        "language": {
          "type": "string",
          "default": "pl",
          "description": "Language code (e.g., 'pl', 'en')"
        },
        "schema_version": {
          "type": "string",
          "default": "resume_maxxer.v1",
          "description": "Canonical Resume Maxxer JSON schema version"
        },
        "template_id": {
          "type": "string",
          "default": "basic_resume_v1",
          "description": "ID of the Typst template to use for rendering"
        }
      }
    },
    "basics": {
      "type": "object",
      "required": ["name", "title", "email", "phone", "location"],
      "properties": {
        "name": {
          "type": "string",
          "example": "Jan Kowalski"
        },
        "title": {
          "type": "string",
          "example": "Specjalista ds. obsługi klienta"
        },
        "targetRole": {
          "type": "string",
          "example": "Kierownik zespołu obsługi klienta"
        },
        "targetCompany": {
          "type": "string",
          "example": "Branża finansowa"
        },
        "targetJobDescription": {
          "type": "string",
          "description": "Full job description used to tailor the resume"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "jan.kowalski@example.com"
        },
        "phone": {
          "type": "string",
          "example": "+48 123 456 789"
        },
        "location": {
          "type": "string",
          "example": "Warszawa, Polska"
        },
        "city": {
          "type": "string",
          "example": "Warszawa"
        },
        "country": {
          "type": "string",
          "example": "Polska"
        },
        "remoteFriendly": {
          "type": "boolean",
          "example": true,
          "description": "Whether remote work is acceptable and should be reflected in generated location"
        },
        "urls": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string", "example": "linkedin.com/in/jankowalski" },
            "github": { "type": "string", "example": "github.com/jankowalski" },
            "portfolio": { "type": "string", "example": "jankowalski.dev" },
            "website": { "type": "string" }
          },
          "additionalProperties": { "type": "string" }
        },
        "summary": {
          "type": "string",
          "description": "Professional summary optimized for ATS keywords"
        }
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["company", "position", "startDate", "endDate"],
        "properties": {
          "company": { "type": "string" },
          "position": { "type": "string" },
          "location": { "type": "string" },
          "startDate": { "type": "string", "description": "YYYY-MM format or YYYY" },
          "endDate": { "type": "string", "description": "YYYY-MM format, YYYY, or 'present' / 'obecnie'" },
          "responsibilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "highlights": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["institution", "degree", "field", "startDate", "endDate"],
        "properties": {
          "institution": { "type": "string" },
          "degree": { "type": "string" },
          "field": { "type": "string" },
          "location": { "type": "string" },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" },
          "gpa": { "type": "string" },
          "coursework": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "keywords"],
        "properties": {
          "category": { "type": "string", "example": "Języki programowania" },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "organization": { "type": "string" },
          "startDate": { "type": "string", "description": "Optional YYYY-MM-DD format" },
          "endDate": { "type": "string", "description": "Optional YYYY-MM-DD format" },
          "period": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string" },
          "keywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "highlights": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["language", "fluency"],
        "properties": {
          "language": { "type": "string", "example": "Angielski" },
          "fluency": { "type": "string", "example": "Full professional proficiency" },
          "certificate": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "issuer", "date"],
        "properties": {
          "name": { "type": "string" },
          "issuer": { "type": "string" },
          "date": { "type": "string" },
          "expires": { "type": "string" },
          "status": { "type": "string" },
          "details": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    }
  }
}
